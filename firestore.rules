rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if the user is a merchant
    function isMerchant() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'merchant';
    }

    // 1. Users collection: Only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // 2. Products collection: Public read (for landing page), but only merchants can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isMerchant();
    }
    
    // 3. Orders collection: 
    // - Customers can create their own orders and read their own orders.
    // - Merchants can read and update all orders.
    match /orders/{orderId} {
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isMerchant());
      allow read, update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isMerchant());
    }

    // 4. Claims collection: Authenticated users/merchants can read and write claims
    match /claims/{claimId} {
      allow read, write: if isAuthenticated();
    }

    // 5. Chats collection: Only participants (consumer or merchant) can read and write chats and messages
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        resource.data.consumerId == request.auth.uid || 
        resource.data.merchantId == request.auth.uid
      );
      allow create, update: if isAuthenticated() && (
        request.resource.data.consumerId == request.auth.uid || 
        request.resource.data.merchantId == request.auth.uid
      );

      // Subcollection for messages inside a chat room
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.consumerId == request.auth.uid ||
          get(/databases/$(database)/documents/chats/$(chatId)).data.merchantId == request.auth.uid
        );
        allow create: if isAuthenticated() && 
          request.resource.data.senderId == request.auth.uid && (
            get(/databases/$(database)/documents/chats/$(chatId)).data.consumerId == request.auth.uid ||
            get(/databases/$(database)/documents/chats/$(chatId)).data.merchantId == request.auth.uid
          );
      }
    }

    // Fallback: Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
